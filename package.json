{
  "name": "x-trends",
  "version": "0.1.0",
  "description": "X (Twitter) trend CLI using emusks — no official API key required",
  "type": "module",
  "bin": {
    "x-trends": "./dist/cli.js"
  },
  "exports": {
    ".": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev:server": "tsx watch src/index.ts",
    "x-trends": "tsx src/cli.ts"
  },
  "dependencies": {
    "@hono/node-server": "^2.0.4",
    "commander": "^12.1.0",
    "dotenv": "^16.5.0",
    "emusks": "^2.3.3",
    "hono": "^4.7.11",
    "zod": "^3.25.51"
  },
  "devDependencies": {
    "@types/node": "^20.19.0",
    "tsup": "^8.5.0",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3"
  }
}
