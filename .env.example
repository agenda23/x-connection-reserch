# x-trends-app / emusks 認証
# ブラウザで x.com にログイン後、DevTools → Application → Cookies → auth_token をコピー
#
# 優先順位（高→低）:
#   1. process.env.TWITTER_AUTH_TOKEN（シェル export / CI）
#   2. DOTENV_PATH または ~/.config/x-trends/.env（グローバル CLI 推奨）
#   3. カレントディレクトリの .env
#   4. パッケージルートの .env（本ファイル — ローカル開発向け）
TWITTER_AUTH_TOKEN=

# --- 以下は本アプリでは任意 ---

# HTTP API 保護用（serve 時）
# API_KEY=

# emusks / サーバー設定
# PORT=3920
# EMUSKS_CLIENT=web
# EMUSKS_ENDPOINT=web
# CACHE_TTL_SECONDS=300
# LOG_LEVEL=info

# --- twitter-cli 用（本アプリでは未使用。共存可） ---
# TWITTER_CT0=
