# x-trends-app / emusks 認証（本アプリはこの値を最優先で自動読み込み）
# ブラウザで x.com にログイン後、DevTools → Application → Cookies → auth_token をコピー
TWITTER_AUTH_TOKEN=

# --- 以下は本アプリでは任意 ---

# HTTP API 保護用（serve 時）
# API_KEY=

# emusks / サーバー設定
# PORT=3920
# EMUSKS_CLIENT=web
# EMUSKS_ENDPOINT=web
# CACHE_TTL_SECONDS=300
# LOG_LEVEL=info

# --- twitter-cli 用（本アプリでは未使用。共存可） ---
# TWITTER_CT0=
